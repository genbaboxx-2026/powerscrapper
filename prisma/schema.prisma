// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String   @id @default(uuid())
  lineUserId            String   @unique @map("line_user_id")
  lineDisplayName       String?  @map("line_display_name")
  linePictureUrl        String?  @map("line_picture_url")
  companyName           String?  @map("company_name")
  businessType          String?  @map("business_type")
  representativeName    String?  @map("representative_name")
  phone                 String?
  email                 String?
  address               String?
  coverageAreas         String[] @map("coverage_areas")
  licenses              String[]
  companyDescription    String?  @map("company_description")
  profileCompleted      Boolean  @default(false) @map("profile_completed")
  lineFriendLinkConsent Boolean  @default(false) @map("line_friend_link_consent")
  role                  String   @default("member")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  projects              Project[]
  bids                  Bid[]
  reviewedProjects      Project[] @relation("ReviewedBy")
  matchesAsPoster       Match[]   @relation("MatchPoster")
  matchesAsBidder       Match[]   @relation("MatchBidder")

  @@map("users")
}

model Project {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  title           String
  recruitmentType String   @map("recruitment_type")
  structureType   String   @map("structure_type")
  floors          String?
  totalArea       String?  @map("total_area")
  siteAddress     String   @map("site_address")
  sitePrefecture  String?  @map("site_prefecture")
  periodStart     String   @map("period_start")
  periodEnd       String   @map("period_end")
  workTypes       String[] @map("work_types")
  description     String
  isUrgent        Boolean  @default(false) @map("is_urgent")
  deadline        DateTime
  status          String   @default("pending")
  rejectionReason String?  @map("rejection_reason")
  notifyMembers   Boolean  @default(true) @map("notify_members")
  reviewedById    String?  @map("reviewed_by")
  reviewedAt      DateTime? @map("reviewed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id])
  reviewedBy      User?    @relation("ReviewedBy", fields: [reviewedById], references: [id])
  bids            Bid[]
  matches         Match[]

  @@map("projects")
}

model Bid {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  userId     String   @map("user_id")
  message    String
  amount     String?
  status     String   @default("submitted")
  selectedAt DateTime? @map("selected_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  project    Project  @relation(fields: [projectId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
  match      Match?

  @@unique([projectId, userId])
  @@map("bids")
}

model Match {
  id             String   @id @default(uuid())
  projectId      String   @map("project_id")
  bidId          String   @unique @map("bid_id")
  posterUserId   String   @map("poster_user_id")
  bidderUserId   String   @map("bidder_user_id")
  posterNotified Boolean  @default(false) @map("poster_notified")
  bidderNotified Boolean  @default(false) @map("bidder_notified")
  createdAt      DateTime @default(now()) @map("created_at")

  project        Project  @relation(fields: [projectId], references: [id])
  bid            Bid      @relation(fields: [bidId], references: [id])
  posterUser     User     @relation("MatchPoster", fields: [posterUserId], references: [id])
  bidderUser     User     @relation("MatchBidder", fields: [bidderUserId], references: [id])

  @@map("matches")
}

model Event {
  id              String   @id @default(uuid())
  title           String
  description     String?
  eventDate       DateTime @map("event_date")
  location        String?
  capacity        Int?
  fee             Int?
  registrationUrl String?  @map("registration_url")
  notified        Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("events")
}
